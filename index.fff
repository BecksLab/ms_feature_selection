\begin{figure}

\centering{

\pandocbounded{\includegraphics[keepaspectratio]{figures/variance_explained.png}}

}

\caption{\label{fig-variance}This figure quantifies the relative
contribution of each structural module to the variance captured by
individual Principal Components (PCs). Calculation: For each PC, the
total variance (eigenvalue) is partitioned among the k=7 modules
identified in the hierarchical clustering. The contribution of a module
to a specific PC is calculated as the sum of the squared loadings of all
metrics belonging to that module, normalised by the total variance
explained by that PC. Visual Interpretation: The alluvial plot
illustrates how the ecological weight shifts across different structural
dimensions. For example, while PC1 may be dominated by a single module,
subsequent PCs often represent a more diverse blend of modular
contributions, reflecting the multifaceted nature of topological
complexity and trophic organization. Significance: This visualisation
confirms that the PC axes are not merely statistical artifacts but are
grounded in the specific groups of correlated metrics defined in the
main text. The stability of the flow across the first several components
demonstrates that the modular organisation of food web architecture is
consistently represented across the primary gradients of structural
variation.}

\end{figure}
\efloatseparator
 
\begin{figure}

\centering{

\pandocbounded{\includegraphics[keepaspectratio]{figures/heatmap_zscores.png}}

}

\caption{\label{fig-alignment_signif}Heatmap showing module--principal
component alignment quantified by permutation-derived Z-scores. Colour
intensity reflects the magnitude and direction of alignment, and
asterisks denote cells that meet joint significance criteria
(permutation P \textless{} 0.05 and \textbar Z\textbar{} \textgreater{}
1.96). Rows correspond to structural metric modules and columns to
principal components. Clustering highlights patterns of shared alignment
across modules and multivariate structural gradients.}

\end{figure}
\efloatseparator
 
\begin{figure}

\centering{

\pandocbounded{\includegraphics[keepaspectratio]{figures/fig_dimensional_reduction.png}}

}

\caption{\label{fig-dim_red}\emph{Figure S1.} Characterisation of
alternative dimensional-reduction approaches for network structural
metrics. (A) Proportion of total variance in the full metric space
retained by each representation: cluster medoids, PC-dominant metrics,
and retained PC scores (≥80\% cumulative variance). (B) Mean absolute
pairwise correlation (\textbar r\textbar) among predictors within each
representation, quantifying internal redundancy. (C) Effective
dimensionality, defined as the number of axes required to explain 80\%
of variance within each reduced predictor set. Together, these
diagnostics illustrate differences in information retention, redundancy,
and structural alignment among dimensional-reduction strategies.}

\end{figure}
\efloatseparator
 
\begin{figure}

\centering{

\pandocbounded{\includegraphics[keepaspectratio]{figures/stability_variance.png}}

}

\caption{\label{fig-stab_var}Contribution of structural modules to
ecosystem stability. Bars show the absolute variance in each stability
metric explained by different structural modules, as estimated via
elastic net regression. Facets correspond to the four stability metrics:
Robustness (\(R_{50}\)), Resilience, Spectral Radius (ρ), and Structural
Controllability. Variance contributions are scaled by the
cross-validated \(R^2\) of the corresponding model, allowing comparison
across metrics. Differences in bar heights across facets indicate which
modules are more influential for particular stability processes.}

\end{figure}
\efloatseparator
 
\begin{figure}

\centering{

\pandocbounded{\includegraphics[keepaspectratio]{figures/stability_estimate.png}}

}

\caption{\label{fig-stab_corr}Standardised elastic net regression
coefficients linking structural predictors to ecosystem stability
metrics. Each point represents a predictor, with vertical lines
extending from zero to the coefficient value. Coefficients are coloured
by structural module and faceted by both network representation (Cluster
Dominant, PC Dominant, PCA Axis, or Complexity) and stability metric.
Positive coefficients indicate that higher values of the predictor
increase the stability metric, while negative coefficients indicate a
suppressive effect. Variation in coefficients across facets reveals
switching of structural predictors' influence on different stability
outcomes.}

\end{figure}
